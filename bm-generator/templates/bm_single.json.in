	"benchmark_config" : {
		"threads": {
		"values": [
			[
			4
			]
		]
		},
		"duration": 60,
		"monitors" : { "mpstat" : ["-n", "-u", "-I", "SCPU,SUM", "-P", "0"],
			       "perf" : ["-C", "0"
      ],
      "bpftrace": {
        "page_fault_io": [
          "-1",
          "-1"
        ],
        "page_fault_kvm": [
          "-1",
          "-1"
        ],
        "page_fault_user": [
          "-1",
          "-1"
        ],
        "page_fault_kernel": [
          "-1",
          "-1"
        ],
        "sched_domains_mutex": [
          "-1",
          "-1"
        ],
        "sched_latency": [
          "-1",
          "-1"
        ],
        "sched_migrate_task": [
          "-1",
          "-1"
        ],
        "sched_fork": [
          "-1",
          "-1"
        ],
        "block_req": [
          "-1",
          "-1"
        ],
        "vfs_read_latency": [
          "-1",
          "-1"
        ],
        "cgroup_rstat_lock": [
          "-1",
          "-1"
        ],
        "cgroup_rstat_flush": [
          "-1",
          "-1"
        ],
        "cgroup_attach_task": [
          "-1",
          "-1"
        ],
        "cgroup_fork": [
          "-1",
          "-1"
        ],
        "cgroup_charge": [
          "-1",
          "-1"
        ],
        "cgroup_procs_write": [
          "-1",
          "-1"
        ],
        "irq_handler": [
          "-1",
          "-1"
        ],
        "mutex_lock": [
          "-1",
          "-1"
        ],
        "raw_spin_lock": [
          "-1",
          "-1"
        ],
        "native_queued_spin_lock_slowpath": [
          "-1",
          "-1"
        ],
        "queued_read_lock_slowpath": [
          "-1",
          "-1"
        ],
        "queued_write_lock_slowpath": [
          "-1",
          "-1"
        ],
        "rwsem_down_read_slowpath": [
          "-1",
          "-1"
        ],
        "rwsem_down_write_slowpath": [
          "-1",
          "-1"
        ],
        "ext4_mb_new_blocks": [
          "-1",
          "-1"
        ],
        "copy_from_user": [
          "-1",
          "-1"
        ],
        "copy_to_user": [
          "-1",
          "-1"
        ],
        "flush_tlb_mm_range": [
          "-1",
          "-1"
        ]
      }
     }
	},
	"containers": {
		"container_list": {"values": [[1], {"min": 4, "step": 4, "max": 96 }]},
		$_begin(META_NAME = [[1]]);
		"port" : 8000,
		$_end();
		"core_count": 1
    },
    "applications": [
$_begin(BINNAME = [[1; 2]]);
        { "name": "BINNAME","operations": [1024]}
$_end();
    ]
	,
	"plugins": [
$_begin(META_NAME = [[1; 2]], GROUP_NAME = [[gen-ws]]);
	 {
		"name": "network-agent.sh",
		"exec_time": "pre",
		"force_stop": "True",
		"args": [
			"8000",
			"{n_units}",
			"{homedir}/build/bench/network",
			"{homedir}/bench/targets/GROUP_NAME/syz/META_NAME"
		]
	 },
$_end();
	{
		"name": "clean-syz.sh",
		"exec_time": "cleanup",
		"args": [
			"{homedir}"
		]
	}
  ]

}
