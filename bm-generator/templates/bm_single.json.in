{
  "plots": [
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "throughput_min",
      "y_lbl": "Throughput",
      "hue_lbl": "Executer",
      "hue": "execution_unit",
      "shape": "barplot",
      "title": "Throughput vs. #Containers"
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "throughput_min",
      "y_lbl": "Throughput",
      "hue": "execution_type",
      "hue_lbl": "Execution Env",
      "title": "Linearity vs. #Containers",
      "type": "linearity"
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "sched_latency",
      "y_lbl": "Schedule Latency (ns)",
      "hue": "execution_type",
      "hue_lbl": "Execution Env",
      "type": "histogram",
      "title": "Schedule Latency vs. #Containers",
      "hist_bucket_min": 0,
      "hist_bucket_max": 2,
      "hist_bucket_factor": 2
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "sched_migrate_task",
      "y_lbl": "#Schedule Migrations",
      "hue": "execution_type",
      "hue_lbl": "Execution Env",
      "type": "min_max_avg",
      "title": "#Schedule Migrations vs. #Containers"
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "vfs_read_latency",
      "y_lbl": "VFS read latency (ns)",
      "hue": "execution_type",
      "hue_lbl": "Execution Env",
      "type": "histogram",
      "title": "VFS read latency vs. #Containers",
      "hist_bucket_min": 0,
      "hist_bucket_max": 2,
      "hist_bucket_factor": 2
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
