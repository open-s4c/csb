{
  "plots": [
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "throughput_min",
      "y_lbl": "Throughput",
      "hue_lbl": "Executer",
      "hue": "execution_unit",
      "shape": "barplot",
      "title": "Throughput vs. #Containers"
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "throughput_min",
      "y_lbl": "Throughput",
      "hue": "execution_type",
      "hue_lbl": "Execution Env",
      "title": "Linearity vs. #Containers",
      "type": "linearity"
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "sched_migrate",
      "y_lbl": "Sched Migration Count",
      "hue": "execution_type",
      "hue_lbl": "Execution Env",
      "shape": "min_max_avg_plot",
      "title": "Scheduling count vs. #Containers"
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "univ_succ_percent",
      "y_lbl": "Operations success percent",
      "hue_lbl": "Executer",
      "hue": "execution_unit",
      "shape": "barplot",
      "title": "Success% vs. #Containers"
    }
  ],
  "benchmark_config": {
    "duration": 10,
    "monitors": {
      "mpstat": [
        "-n",
        "-u",
        "-I",
        "SCPU,SUM",
        "-P",
        "0"
      ],
      "perf": [
        "-C",
        "0"
      ],
      "bpftrace": {
        "sched_latency": [
          "-1",
          "-1"
        ],
        "sched_migrate_task": [
          "-1",
          "-1"
        ],
        "sched_fork": [
          "-1",
          "-1"
        ],
        "block_req": [
          "-1",
          "-1"
        ],
        "vfs_read_latency": [
          "-1",
          "-1"
        ]
      }
    }
  },
  "containers": {
    "container_list": {
      "values": [
        [
          1
        ],
        {
          "min": 2,
          "step": 1,
          "max": 4
        }
      ]
    },
    "core_count": 1
  },
  "applications": [
    {
      "name": "rocksdb_min_rocks_fcntl_pread64_0_0",
      "operations": [
        1024
      ]
    }
  ],
  "plugins": [
    {
      "name": "clean-syz.sh",
      "exec_time": "cleanup",
      "args": [
        "{homedir}"
      ]
    }
  ]
}