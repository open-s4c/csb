{
	"plots": [
		{
			"x": "container_cnt",
			"x_lbl": "#Containers",
			"y": "throughput_min",
			"y_lbl": "Throughput",
			"hue_lbl": "Executer",
			"hue": "execution_unit",
			"shape": "barplot",
			"title" : "Throughput vs. #Containers"
		},
		{
			"x": "container_cnt",
			"x_lbl": "#Containers",
			"y": "throughput_min",
			"y_lbl": "Throughput",
			"hue": "execution_type",
			"hue_lbl": "Execution Env",
			"title": "Linearity vs. #Containers",
			"type": "linearity"
		},
		{
			"x": "container_cnt",
			"x_lbl": "#Containers",
			"y": "univ_succ_percent",
			"y_lbl": "Operations success percent",
			"hue_lbl": "Executer",
			"hue": "execution_unit",
			"shape": "barplot",
			"title" : "Success% vs. #Containers"
		}
	],
	"benchmark_config" : {
		"duration": 60,
		"monitors" : { "mpstat" : ["-n", "-u", "-I", "SCPU,SUM", "-P", "0"],
			       "perf" : ["-C", "0"]
			     }
	},
	"containers": {
		"container_list": {"values": [[1], {"min": 5, "step": 5, "max": 30 }]},
		"core_count": 1,
		"port" : 8000
    },
    "applications": [
        { "name": "mysql_v2_min_mysql_recvfrom_sendto_32_0","operations": [1024]}
    ]
	,
	"plugins": [
	 {
		"name": "generic-network-client.sh",
		"exec_time": "pre",
		"force_stop": "True",
		"args": [
			"8000",
			"{n_units}",
			"{homedir}/build/bench/network/client",
			"{homedir}/bench/targets/mysql_v2/syz/min_mysql_recvfrom_sendto_32_0.meta"
		]
	 }
  ]
}
