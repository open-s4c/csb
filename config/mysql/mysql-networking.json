{
  "plots": [
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "throughput_min",
      "y_lbl": "Throughput",
      "hue_lbl": "Executer",
      "hue": "execution_unit",
      "shape": "barplot",
      "title": "Throughput vs. #Containers"
    },
    {
      "x": "container_cnt",
      "x_lbl": "#Containers",
      "y": "univ_succ_percent",
      "y_lbl": "Operations success percent",
      "hue_lbl": "Executer",
      "hue": "execution_unit",
      "shape": "barplot",
      "title": "Success% vs. #Containers"
    }
  ],
  "benchmark_config": {
    "duration": 60,
    "monitors": {
      "mpstat": [
        "-n",
        "-u",
        "-I",
        "SCPU,SUM",
        "-P",
        "0,1"
      ],
      "perf": [
        "-a"
      ]
    },
    "exec_env": [
      "container"
    ]
  },
  "containers": {
    "container_list": {
      "values": [
        [
          3
        ]
      ]
    },
    "core_count": 2,
    "port": 8000
  },
  "applications": [
    {
      "name": "mysql_min_mysql_recvfrom_sendto_0_0",
      "operations": [
        1024
      ]
    },
    {
      "name": "mysql_min_mysql_recvfrom_sendto_20_0",
      "operations": [
        1024
      ]
    },
    {
      "name": "mysql_min_mysql_recvfrom_sendto_32_0",
      "operations": [
        1024
      ]
    }
  ],
  "plugins": [
    {
      "name": "generic-network-client.sh",
      "exec_time": "pre",
      "force_stop": "True",
      "args": [
        "8000",
        "3",
        "{homedir}/build/bench/network/client",
        "{homedir}/bench/targets/mysql/syz/min_mysql_recvfrom_sendto_0_0.meta",
        "{homedir}/bench/targets/mysql/syz/min_mysql_recvfrom_sendto_20_0.meta",
        "{homedir}/bench/targets/mysql/syz/min_mysql_recvfrom_sendto_32_0.meta"
      ]
    },
    {
      "name": "clean-syz.sh",
      "exec_time": "cleanup",
      "args": [
        "{homedir}"
      ]
    }
  ]
}
